union Opt T
    object None: Opt
    struct Some: Opt
        val value: T

impl Opt T
    fn isSome self: Bool
        match self
        | Opt'None -> False
        | Opt'Some { value, .. } -> True

    fn isNone self: Bool
        match self
        | Opt'None -> True
        | Opt'Some { value, .. } -> False

import Stride'Engine'Game
import Stride'Games'GameTime

data FlappyGame =
    { _shouldUpdate: Bool }

impl FlappyGame as Game
    fn new: FlappyGame =
        FlappyGame { _shouldUpdate = True }

    fn Initialize self: () =
        base'Initialize.

    fn Update self (gameTime: GameTime): () =
        if | self'_shouldUpdate =>
                gameTime base'Update.
            | else => ()

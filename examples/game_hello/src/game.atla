import Stride'Engine'Game
import Stride'Games'GameTime

data FlappyGame =
    { _initialized: Bool }

impl FlappyGame as Game
    fn new: FlappyGame =
        FlappyGame { _initialized = False }

    fn Initialize self: () =
        base'Initialize.
        self'_initialized = True

    fn Update self (gameTime: GameTime): () =
        gameTime base'Update.

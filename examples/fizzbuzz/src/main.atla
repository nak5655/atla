import System'Array
import System'Console

fn fizzbuzz (n: Int): ()
    for i in 1 (n + 1) range.
        val s =
            if
            | i % 15 == 0 => "FizzBuzz"
            | i % 5 == 0 => "Buzz"
            | i % 3 == 0 => "Fizz"
            | else => i'ToString.
        s Console'WriteLine.

fn main: ()
    val n = Console'ReadLine. Int32'Parse.
    n fizzbuzz.

import Avalonia.Application
import Avalonia.Controls.Window
import Avalonia.Controls.AppBuilder

fn appMain (app: Application) (args: Array String): () = do
    let window = Window ()
    window.Show ()
    app.Run window

fn main (args: Array String): Int = do
    let config = AppBuilder.Configure[Application] ()
    let config2 = config.UsePlatformDetect ()
    config2.Start appMain args
